# Find all directories containing .terraform.lock.hcl files
workspaces := `find . -name ".terraform.lock.hcl" -exec dirname {} \; | tr '\n' ' '`

# Show available recipes
default:
    @just --list

# Format OpenTofu files in all workspaces
format:
    @echo "Formatting OpenTofu files in all workspaces..."
    @for workspace in {{workspaces}}; do \
        echo "Formatting $workspace"; \
        tofu -chdir=$workspace fmt; \
    done
    @echo "Formatting complete."

# List all detected OpenTofu workspaces
list-workspaces:
    @echo "Detected OpenTofu workspaces:"
    @for workspace in {{workspaces}}; do \
        echo "  $workspace"; \
    done

# Validate OpenTofu configurations in all workspaces
validate:
    @echo "Validating OpenTofu configurations in all workspaces..."
    @for workspace in {{workspaces}}; do \
        echo "Validating $workspace"; \
        tofu -chdir=$workspace validate; \
    done
    @echo "Validation complete."

# Initialize OpenTofu in all workspaces
init:
    @echo "Initializing OpenTofu in all workspaces..."
    @for workspace in {{workspaces}}; do \
        echo "Initializing $workspace"; \
        tofu -chdir=$workspace init; \
    done
    @echo "Initialization complete."

# Initialize and upgrade OpenTofu in all workspaces
init-upgrade:
    @echo "Initializing and upgrading OpenTofu in all workspaces..."
    @for workspace in {{workspaces}}; do \
        echo "Initializing and upgrading $workspace"; \
        tofu -chdir=$workspace init -upgrade; \
    done
    @echo "Initialization and upgrade complete."

# Run OpenTofu plan in all workspaces
plan:
    @echo "Running OpenTofu plan in all workspaces..."
    @for workspace in {{workspaces}}; do \
        echo "Planning $workspace"; \
        tofu -chdir=$workspace plan; \
    done
    @echo "Planning complete."

# Remove OpenTofu cache files from all workspaces
[confirm("This will delete .terraform, tfstate, and lock files. Continue?")]
clean:
    @echo "Cleaning OpenTofu cache files from all workspaces..."
    @for workspace in {{workspaces}}; do \
        echo "Cleaning $workspace"; \
        rm -rf $workspace/.terraform $workspace/*.tfstate* $workspace/.terraform.lock.hcl; \
    done
    @echo "Cleaning complete."
