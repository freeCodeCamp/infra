# Copy to terraform.tfvars (gitignored) and fill in.
#
# Token comes from env:
#   export DIGITALOCEAN_TOKEN="$(sops -d --extract '["DO_API_TOKEN"]' \
#       ../infra-secrets/do-universe/.env.enc)"
#
# Required input: ssh_key_ids (DO numeric ids; output of
#   `doctl compute ssh-key list --no-header`).
#
# Strongly recommended: operator_ssh_cidrs (workstation/jumpbox CIDR
# allowed inbound :22). Empty list = no SSH allowed; safe for steady
# state but breaks operator bootstrap.

ssh_key_ids        = []
operator_ssh_cidrs = []

